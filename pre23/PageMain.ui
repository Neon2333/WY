     <property name="styleSheet">
      <string notr="true">QFrame{
border-radius: 10px;        /* 圆角半径，可根据需要调整 */
background-color: rgb(255, 255, 255);
}
/* 正常状态 */
QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid #229590;
    border-radius: 4px;
}

/* 选中状态 */
QCheckBox::indicator:checked {
    background: #2dc6be;
    border: 2px solid #229590;

}

/* 禁用状态 */
QCheckBox::indicator:disabled {
    background: #a7a7a7;
    border: 2px solid #229590;
}

QPushButton {
    background-color: #229590;  /* 蓝色背景 */
    color: white;
    border-radius: 6px;        /* 圆角大小 */
    padding: 6px 12px;          /* 内边距 */
}

/* 按钮按下效果 */
QPushButton:pressed,
QPushButton[touchPressed=&quot;true&quot;]
 {
    background-color: #16615e;
    padding-top: 8px;
    padding-bottom: 4px;
}


QPushButton:disabled {
    background-color: #a7a7a7;
    color: white;
    border-radius: 10px;
    padding: 6px 12px;
}</string>
     </property>
