  <property name="styleSheet">
   <string notr="true">QPushButton {
    background-color: #229590;  /* 蓝色背景 */
    color: white;
    border-radius: 10px;        /* 圆角大小 */
    padding: 6px 12px;          /* 内边距 */
}


/* 按钮按下效果 */
QPushButton:pressed {
    background-color: #16615e;  /* 更深的颜色 */
    padding-top: 7px;          /* 模拟下沉效果 */
    padding-bottom: 5px;
    margin-top: 1px;           /* 保持总高度不变 */
} 

QFrame
{
background-color: rgb(255, 255, 255);
border-radius: 10px; 
}

QComboBox:disabled {
    border: 2px solid #229590;
    border-radius: 6px;
    padding: 4px 8px;
    color: #666666;
}

QPushButton:disabled {
    background-color: #a7a7a7;
    color: white;
    border-radius: 10px;
    padding: 6px 12px;
}

QLineEdit:disabled {
    border-radius: 15px;
    border: 2px solid rgb(34, 149, 144);
    padding: 4px;
    color: #666666;
}</string>
