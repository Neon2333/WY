         <string notr="true">QProgressBar {
    /* 进度条整体样式 */
    border: 2px solid rgb(167, 167, 167);;
    border-radius: 8px;
}

QProgressBar::chunk {
    /* 进度填充部分的样式 */
    background-color: rgb(34, 149, 144);  /* 进度条颜色 */
	border-radius: 3px;  /* 减小圆角，让分段更明显 */
    width: 13px;  /* 控制每个块的宽度，越小分段越多 */
    margin: 3px;  /* 块之间的间距，创建分段效果 */
}</string>
