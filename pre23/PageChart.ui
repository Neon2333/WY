        <property name="styleSheet">
         <string notr="true">QComboBox {
    background-color: #229590;
    color: #ffffff;
    border: 3px solid #26c6da;
    border-radius: 6px;
    padding: 4px 8px;
}
QComboBox::drop-down {

    width: 15px;
}

/* 这是控制下拉选项背景的关键部分 */
QComboBox QAbstractItemView {
    background-color: #229590; /* 下拉选项背景色 */
    color: #ffffff; /* 下拉选项文字颜色 */
    selection-background-color: #00ff00; /* 下拉选项中选中项的背景色 */
    border: 1px solid #26c6da; /* 下拉选项边框 */
    outline: 0; /* 移除选中项的虚线框 */
    border-radius: 6px; /* 下拉选项圆角 */
}</string>
        </property>
        <property name="currentText">
         <string notr="true">日期筛选模式</string>
        </property>
