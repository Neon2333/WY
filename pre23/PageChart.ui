      <string notr="true">/* 滑轨：实际高度大，颜色区域小 */
QSlider::groove:horizontal {
    height: 52px;               /* 实际轨道高度足够放下大滑块 */
    background: transparent;     /* 透明，颜色用 sub-page / add-page 控制 */
}

/* 已选中部分 */
QSlider::sub-page:horizontal {
    background: rgb(34, 149, 144); /* 蓝色条 */
    height: 16px;                  /* 只占 groove 中间一小段 */
    margin: 14px 0;                /* 上下居中显示 */
    border-radius: 8px;
}

/* 未选中部分 */
QSlider::add-page:horizontal {
    background: rgb(152, 197, 198); /* 灰色条 */
    height: 16px;                  /* 和 sub-page 一样 */
    margin: 12px 0;                /* 上下居中 */
    border-radius: 8px;
}

/* 滑块 */
QSlider::handle:horizontal {
    background: rgb(45, 198, 190);
    width: 28px;
    height: 36px;       /* 大于轨道颜色区域 */
    border-radius: 10px;
    margin: 2px 0;      /* 上下略覆盖轨道 */
    transition: all 0.15s ease;
}

/* 鼠标悬停或按下滑块 */
QSlider::handle:horizontal:hover,
QSlider::handle:horizontal:pressed {
    height: 40px;       /* 高度放大 */
	background: rgb(0, 170, 0);
}
