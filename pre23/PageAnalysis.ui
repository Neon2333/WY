      </font>
     </property>
     <property name="styleSheet">
      <string notr="true">QFrame
{
	border-radius: 15px;        /* 圆角半径，可根据需要调整 */
	background-color: white;    /* 可选：背景色 */	
}

/* 正常状态 */
QCheckBox::indicator {
    width: 25px;
    height: 25px;
    border: 2px solid #229590;
    border-radius: 4px;
}

/* 选中状态 */
QCheckBox::indicator:checked {
    background: #2dc6be;
    border: 2px solid #229590;
}

/* 禁用状态 */
QCheckBox::indicator:disabled {
    background: #a7a7a7;
    border: 2px solid #229590;
}

QPushButton
{
	background-color: rgb(34, 149, 144);
    color: white;
    border-radius: 10px;        /* 圆角大小 */
    padding: 6px 12px;          /* 内边距 */

}
/* 按钮按下效果 */
QPushButton:pressed {
    background-color: #16615e;  /* 更深的颜色 */
    padding-top: 7px;          /* 模拟下沉效果 */
    padding-bottom: 5px;
    margin-top: 1px;           /* 保持总高度不变 */
}


QComboBox {
    background-color: #229590;
    color: #ffffff;
    border: 3px solid #26c6da;
    border-radius: 6px;
    padding: 4px 8px;
}

QComboBox::drop-down {

    width: 15px;
}

/* 这是控制下拉选项背景的关键部分 */
QComboBox QAbstractItemView {
    background-color: #229590; /* 下拉选项背景色 */
    color: #ffffff; /* 下拉选项文字颜色 */
    selection-background-color: #00ff00; /* 下拉选项中选中项的背景色 */
    border: 1px solid #26c6da; /* 下拉选项边框 */
    outline: 0; /* 移除选中项的虚线框 */
    border-radius: 6px; /* 下拉选项圆角 */
}
QComboBox:disabled {
    border: 2px solid #229590;
    border-radius: 6px;
    padding: 4px 8px;
    color: #666666;
}

QPushButton:disabled {
    background-color: #a7a7a7;
    color: white;
    border-radius: 10px;
    padding: 6px 12px;
}

QLineEdit:disabled {
    border-radius: 15px;
    border: 2px solid rgb(34, 149, 144);
    padding: 4px;
    color: #666666;
}</string>
     </property>
