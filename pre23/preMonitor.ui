        <property name="styleSheet">
         <string notr="true">/* QFrame 的样式（设置圆角和背景色） */
QFrame {
    background-color: rgb(34, 149, 144);
    border-bottom-left-radius: 20px;
    border-bottom-right-radius: 20px;
    padding: 0px;        /* 移除内边距 */
}

/* QListWidget 的样式（背景透明，仅保留项样式） */
QListWidget {
    background-color: transparent;  /* 关键：背景透明 */
    border: none;                  /* 移除边框 */
    padding: 8px 0px 0px 0px;      /* 仅顶部留空隙 */
}

QListWidget::item {
    margin: 4px 8px;
    padding: 12px 16px;
    color: white;
    min-height: 36px;
    border-radius: 8px;
}


/* 其他样式保持不变 */
QListWidget::item:selected {
    background-color: white;
    color: rgb(34, 149, 144);
    font-weight: bold;
    border: 2px solid rgb(34, 149, 144);
}

QListWidget::item:hover {
    background-color: rgb(26, 130, 125);
}</string>
